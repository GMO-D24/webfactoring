{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "faqs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "answer"
        ],
        "additionalProperties": false
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "draft",
    "faqs"
  ],
  "additionalProperties": false
}